{
  "name": "openclaw-electron",
  "private": true,
  "version": "0.1.0",
  "description": "OpenClaw cross-platform Electron shell",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs/promises').then(async (fs)=>{await fs.rm('dist',{recursive:true,force:true});})\"",
    "dev": "pnpm run build && electron dist/main.js",
    "dist": "electron-builder --config electron-builder.yml",
    "dist:mac": "electron-builder --config electron-builder.yml --mac",
    "dist:win": "electron-builder --config electron-builder.yml --win",
    "dist:linux": "electron-builder --config electron-builder.yml --linux",
    "pack": "electron-builder --config electron-builder.yml --dir"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  }
}
